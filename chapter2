function mul_cols(A, x)   # 按列访问的矩阵乘法
    m,n = size(A)
    c = zeros(m)
    for j = 1:n, k = 1:m
        c[k] += A[k, j] * x[j]
    end
    c
end
（基础矩阵乘法实现，为后续优化打基础）

M6
function ldiv(L::LowerTriangular, b)   # 前代法解下三角系统
    n = size(L,1)
    x = zeros(n)
    for k = 1:n
        r = b[k]
        for j = 1:k-1
            r -= L[k,j] * x[j]
        end
        x[k] = r / L[k,k]
    end
    x
end
（直接对应 computerexam2324s.ipynb 问题6 中 LowerTridiagonal 的 \ 求解，以及 computerexam2122s.ipynb 问题3.2 中的 * 操作，原理相同）

