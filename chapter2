function ldiv(U::UpperTriangular, b)   # 回代法解上三角系统
    n = size(U,1)
    x = zeros(n)
    for k = n:-1:1
        r = b[k]
        for j = k+1:n
            r -= U[k,j] * x[j]
        end
        x[k] = r / U[k,k]
    end
    x
end
（同上，上三角版本，对应 computerexam2324s.ipynb 问题6 的 \ 操作）

M9
struct UpperTridiagonal <: AbstractMatrix{Float64}
    d; du; du2
end
function getindex(U::UpperTridiagonal, k::Int, j::Int)
    if j == k+2; return U.du2[k]
    elseif j == k+1; return U.du[k]
    elseif j == k; return U.d[k]
    else; return 0.0
    end
end
function setindex!(U::UpperTridiagonal, v, k::Int, j::Int)
    if j == k+2; U.du2[k] = v
    elseif j == k+1; U.du[k] = v
    elseif j == k; U.d[k] = v
    else; error("off-band")
    end
end
（自定义带状矩阵类型，与 computerexam2324s.ipynb 问题6 的 LowerTridiagonal 对称，直接对应其实现）

M10
function *(U::UpperTridiagonal, x::AbstractVector)   # O(n) 乘法
    n = size(U,1)
    b = zeros(n)
    for j = 1:n, k = max(j-2,1):j
        b[k] += U[k,j] * x[j]
    end
    b
end
（O(n) 乘法，对应 computerexam2324s.ipynb 问题6 中 LowerTridiagonal 的 * 操作，也是 mockexams.ipynb 问题6 的要求）

M11
function \(U::UpperTridiagonal, b::AbstractVector)   # O(n) 求解
    n = size(U,1)
    x = zeros(n)
    for k = n:-1:1
        r = b[k]
        for j = k+1:min(n, k+2)
            r -= U[k,j] * x[j]
        end
        x[k] = r / U[k,k]
    end
    x
end
（O(n) 求解，对应 computerexam2324s.ipynb 问题6 的 \ 操作）

