# 定义一个辅助函数：若 x==0 则返回 NaN，否则返回 |x|
nanabs(x) = x == 0 ? NaN : abs(x)

# 加载绘图库
using Plots

# 节点数从 2 到 100
ns = 2:100

# 计算函数 exp(x) 的积分误差（每个 n 对应一个误差值）
errs = [(x = range(0,1,n);                     # 生成 n 个等距节点
         nanabs(interpolatoryquadrature(exp.(x), x) - (exp(1)-1))) 
        for n=ns]

# 绘制 exp(x) 的误差曲线，纵坐标为对数坐标
plot(ns, errs; yscale=:log10)   # 误差呈指数衰减

# 计算函数 1/(25x^2+1) 的积分误差（双精度）
errs = [(x = range(0,1,n); 
         nanabs(interpolatoryquadrature(1 ./ (25x.^2 .+ 1), x) - atan(5)/5)) 
        for n=ns]
plot!(ns, errs; yscale=:log10)  # 叠加到同一图，误差起初下降但很快停滞

# 使用高精度 BigFloat 重新计算第二个函数的误差
errs = [(x = range(0,big(1),n); 
         nanabs(interpolatoryquadrature(1 ./ (25x.^2 .+ 1), x) - atan(big(5))/5)) 
        for n=ns]
plot!(ns, errs; yscale=:log10)  # 叠加，误差可继续下降


