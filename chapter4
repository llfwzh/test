9.使用最小二乘法逼近函数 1/(10x^2 + 1) 和 1/(25x^2 + 1)

# 使用最小二乘法逼近函数 1/(4x^2+1) 和 1/(25x^2+1)
n = 50                      # 使用基函数 [1, x, …, x^(49)]，即最高49次的多项式
𝐱 = range(-1, 1; length=500) # 在[-1,1]上均匀取500个点作为最小二乘的样本点
𝐠 = range(-1, 1; length=2000) # 在[-1,1]上均匀取2000个点用于绘制拟合曲线
V = 𝐱 .^ (0:n-1)'           # 构造500×50的范德蒙矩阵，每列对应样本点的不同幂次
V_g = 𝐠 .^ (0:n-1)'         # 构造2000×50的范德蒙矩阵，用于计算绘图点上的多项式值
f_4 = x -> 1/(4x^2 + 1)     # 定义第一个目标函数 f_4(x) = 1/(4x^2+1)
𝐜_4 = V \ f_4.(𝐱)            # 求解最小二乘问题，得到拟合 f_4 的多项式系数
f_25 = x -> 1/(25x^2 + 1)   # 定义第二个目标函数 f_25(x) = 1/(25x^2+1)
𝐜_25 = V \ f_25.(𝐱)          # 求解最小二乘问题，得到拟合 f_25 的多项式系数
plot(𝐠, V_g*𝐜_4; ylims=(-1,1))   # 绘制第一个函数的拟合曲线
plot!(𝐠, V_g*𝐜_25)                # 在同一图中叠加第二个函数的拟合曲线
# 结果：两个近似看起来都在收敛。
# 尽管这两个函数的泰勒级数收敛半径都小于区间[-1,1]的长度，
# 但最小二乘法依然能够给出良好的拟合。
  
