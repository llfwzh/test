7.插值型求积公式的权重公式

  function interpolatoryweights(x::AbstractVector)
    n = length(x)
    # 构造范德蒙矩阵 V，其中第 j 列为 x.^(j-1)
    V = x .^ (0:n-1)'   # 利用广播，x 是列向量，指数是行向量，得到 n×n 矩阵
    # 求解线性系统 V' * w = [1, 1/2, ..., 1/n]
    # 注意右端项 1 ./ (1:n) 对应 1, 1/2, ..., 1/n
    V' \ (1 ./ (1:n))
end
#测试
@test interpolatoryweights([0,1/4,1]) ≈ [-1/6, 8/9, 5/18]

