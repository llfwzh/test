8.Householder 反射实现 QR（高效版本，使用 Reflection 和 Reflections）
"""
    householderqr(A)

返回 (Q, R)，其中 Q 是 Reflections 类型（存储 Householder 向量），R 是上三角矩阵（包括零行），满足 Q*R ≈ A。
复杂度 O(mn²)。
"""
function householderqr(A)
    T = eltype(A)
    m, n = size(A)
    n > m && error("列数不能超过行数")
    R = zeros(T, m, n)                 # 最终 R 矩阵（包含零行）
    Q = Reflections(zeros(T, m, n))    # Q.V 将存储 Householder 向量
    Aⱼ = copy(A)                        # 当前待处理的子矩阵
    for j = 1:n
        𝐚₁ = Aⱼ[:, 1]                    # 当前第一列
        Q₁ = householderreflection(𝐚₁[1] < 0, 𝐚₁)   # 构造 Householder 反射
        Q₁Aⱼ = Q₁ * Aⱼ                    # 应用到当前子矩阵
        α, 𝐰 = Q₁Aⱼ[1, 1], Q₁Aⱼ[1, 2:end]  # 第一行第一列和剩余行
        R[j, j] = α
        R[j, j+1:end] = 𝐰
        Q.V[j:end, j] = Q₁.v              # 存储 Householder 向量（截断）
        Aⱼ = Q₁Aⱼ[2:end, 2:end]           # 进入下一轮子矩阵
    end
    return Q, R
end

# 测试
A = randn(600, 400)
Q, R = householderqr(A)
@test Q*R ≈ A

9.Givens 旋转实现带状矩阵 QR（O(n) 时间）

#首先需要定义 UpperTridiagonal 类型（带两条上对角线的上三角矩阵）
# 自定义上三角矩阵，带宽 (0,2)
struct UpperTridiagonal{T} <: AbstractMatrix{T}
    d::Vector{T}   # 对角线
    du::Vector{T}  # 第一次上对角线
    du2::Vector{T} # 第二次上对角线
end

import Base: size, getindex, setindex!

size(U::UpperTridiagonal) = (length(U.d), length(U.d))

function getindex(U::UpperTridiagonal, k::Int, j::Int)
    if j - k == 0
        return U.d[k]
    elseif j - k == 1
        return U.du[k]
    elseif j - k == 2
        return U.du2[k]
    else
        return zero(eltype(U))
    end
end

function setindex!(U::UpperTridiagonal, v, k::Int, j::Int)
    if j > k+2 || j < k
        error("无法修改带外元素")
    end
    if j - k == 0
        U.d[k] = v
    elseif j - k == 1
        U.du[k] = v
    elseif j - k == 2
        U.du2[k] = v
    end
    return U
end

#现在实现带状 QR（针对三对角矩阵，利用 Givens 旋转）。
"""
    bandedqr(A::Tridiagonal)

返回 (Q, R)，其中 Q 是 Rotations 类型（存储旋转角度），R 是 UpperTridiagonal，
满足 Q*R ≈ A。复杂度 O(n)。
"""
function bandedqr(A::Tridiagonal)
    n = size(A, 1)
    Q = Rotations(zeros(n-1))                     # 存储 n-1 个旋转角度
    R = UpperTridiagonal(zeros(n), zeros(n-1), zeros(n-2))
    R[1, 1:2] = A[1, 1:2]                          # 初始化第一行
    for j = 1:n-1
        # 当前待消去的元素是 (j+1, j)
        x_1 = [R[j, j], A[j+1, j]]                 # 两个元素构成向量
        Q.θ[j] = atan(x_1[2], x_1[1])               # 计算旋转角度
        Q_1 = Rotation(-Q.θ[j])                     # 旋转矩阵（逆方向）
        R[j, j] = (Q_1 * x_1)[1]                    # 更新对角元
        # 应用到第 j+1 列
        x_2 = [R[j, j+1]; A[j+1, j+1]]
        R[j:j+1, j+1] = Q_1 * x_2
        # 应用到第 j+2 列（若存在）
        if j < n-1
            x_3 = [0.0, A[j+1, j+2]]
            R[j:j+1, j+2] = Q_1 * x_3
        end
    end
    return Q, R
end

# 测试
A = Tridiagonal([1,2,3,4], [1,2,3,4,5], [1,2,3,4])
Q, R = bandedqr(A)
@test Q*R ≈ A

10.QR 与最小二乘
"""
    leastsquares(A, b)

返回最小二乘解 x 使得 ‖Ax - b‖₂ 最小，使用 Householder QR 分解。
"""
function leastsquares(A, b)
    m, n = size(A)
    Q, R = householderqr(A)
    # 缩减 QR：取 R 的前 n 行，Q'b 的前 n 个元素
    return UpperTriangular(R[1:n, 1:n]) \ (Q'b)[1:n]
end

# 与 Julia 内置 \ 对比
