5.cholesky分解
#先检验是不是可以这样分解的，也就是正定性
function mycholesky(A)
    T = eltype(A)
    m,n = size(A)
    n == m || error("矩阵必须为方阵")
    A ≈ A' || error("矩阵必须对称")
    L = LowerTriangular(zeros(T,n,n))
    Aⱼ = copy(A)
    for j = 1:n
        α,𝐯 = Aⱼ[1,1], Aⱼ[2:end,1]
        α ≤ 0 && error("矩阵不是正定的")
        L[j,j] = sqrt(α)
        L[j+1:end,j] = 𝐯 / sqrt(α)
        Aⱼ = Aⱼ[2:end,2:end] - 𝐯*𝐯' / α
    end
    return L
end

A = Symmetric(rand(100,100) + 100I)
L = mycholesky(A)
@test A ≈ L*L'

# 内置版本
L̃ = cholesky(A).L
@test L̃ ≈ L

#分解
function mycholesky(A::SymTridiagonal)
    d = A.dv
    u = A.ev
    T = float(eltype(A))
    n = length(d)
    ld = zeros(T, n)
    ll = zeros(T, n-1)
    ld[1] = sqrt(d[1])
    for k = 1:n-1
        ll[k] = u[k] / ld[k]
        ld[k+1] = sqrt(d[k+1] - ll[k]^2)
    end
    return Bidiagonal(ld, ll, :L)
end

n = 1000
A = SymTridiagonal(2*ones(n), -ones(n-1))
L = mycholesky(A)
@test L isa Bidiagonal
@test L*L' ≈ A

6.二维旋转矩阵，存储角度 θ
  
# 定义一个二维旋转矩阵类型，存储角度（弧度）
struct Rotation <: AbstractMatrix{Float64}
    θ::Float64
end

import Base: *, size, getindex

size(Q::Rotation) = (2, 2)

# 实现旋转矩阵与向量的乘法（O(1) 时间）
function *(Q::Rotation, x::AbstractVector)
    length(x) == 2 || error("向量长度必须为 2")
    c, s = cos(Q.θ), sin(Q.θ)
    a, b = x
    return [c*a - s*b, s*a + c*b]
end

# 获取矩阵元素 (k,j) —— 通过乘以标准基向量实现
function getindex(Q::Rotation, k::Int, j::Int)
    e_k = zeros(2); e_k[k] = 1
    e_j = zeros(2); e_j[j] = 1
    return (e_k' * (Q * e_j))[]  # 取出标量
end

# 示例：将向量旋转至 x 轴
x = [-1.0, -2.0]
θ = atan(x[2], x[1])          # 计算向量角度
Q = Rotation(-θ)               # 旋转回 x 轴
@test Q * x ≈ [norm(x), 0.0]

7.多个旋转复合
# 表示一系列反射的乘积，Q = Q_{v₁} Q_{v₂} … Q_{vₘ}
struct Reflections{T} <: AbstractMatrix{T}
    V::Matrix{T}          # 每一列是一个 Householder 向量（单位向量）
end

size(Q::Reflections) = (size(Q.V, 1), size(Q.V, 1))

# 复合反射乘以向量：从最后一个反射开始依次应用
function *(Q::Reflections, x::AbstractVector)
    m, n = size(Q.V)
    for j = n:-1:1
        x = Reflection(Q.V[:, j]) * x
    end
    return x
end

# 获取元素 (k,j) —— 通过乘以单位向量 O(mn)
function getindex(Q::Reflections, k::Int, j::Int)
    m, n = size(Q)
    eⱼ = zeros(eltype(Q.V), m)
    eⱼ[j] = one(eltype(Q.V))
    return (Q * eⱼ)[k]
end

# 伴随（即逆）也是 Reflections，但向量顺序颠倒
function adjoint(Q::Reflections)
    return Reflections(Q.V[:, end:-1:1])
end

